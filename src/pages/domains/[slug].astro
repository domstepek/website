---
import DomainPage from "../../components/domains/DomainPage.astro";
import BaseLayout from "../../components/layout/BaseLayout.astro";
import { domains, getDomainBySlug } from "../../data/domains";
import { domainPath } from "../../lib/paths";

export const getStaticPaths = () =>
  domains.map((domain) => ({
    params: { slug: domain.slug },
  }));

const slug = Astro.params.slug ?? "";
const domain = getDomainBySlug(slug);

if (!domain) {
  throw new Error(`Unknown domain slug: ${slug}`);
}
---

<BaseLayout
  title={domain.title}
  description={domain.seoDescription}
  canonicalPath={domainPath(domain.slug)}
>
  <DomainPage domain={domain} />
</BaseLayout>
