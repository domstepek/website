---
import BaseLayout from "../../components/layout/BaseLayout.astro";
---

<BaseLayout title="Shader Demo" noindex>
  <canvas id="shader-canvas"></canvas>
  <div class="overlay">
    <p>shader engine demo — check console for renderer info</p>
  </div>
</BaseLayout>

<style>
  #shader-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: -1;
  }

  .overlay {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    pointer-events: none;
  }

  .overlay p {
    font-family: var(--font-mono);
    font-size: var(--step-0);
    color: var(--muted);
    background: rgba(10, 10, 10, 0.7);
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
  }
</style>

<script>
  import { initDitherShader } from "../../lib/shader/dither-shader.js";

  const canvas = document.getElementById("shader-canvas") as HTMLCanvasElement;
  if (canvas) {
    const instance = await initDitherShader(canvas);
    // Store for potential cleanup
    if (instance) {
      (window as any).__shaderInstance = instance;
    }
  }
</script>
