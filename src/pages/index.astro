---
import { siteConfig } from "../data/site";
import { assetPath, canonicalUrl, homePath } from "../lib/paths";

const pageTitle = siteConfig.defaultTitle;
const description = siteConfig.defaultDescription;
const socialImagePath = assetPath(siteConfig.defaultSocialImage);
const pageCanonicalUrl = canonicalUrl("/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageCanonicalUrl} />
  </head>
  <body>
    <main>
      <h1>{siteConfig.name}</h1>
      <p>publishing foundation in progress.</p>
      <p>{description}</p>
      <ul>
        <li><a href={homePath}>base-aware home path</a></li>
        <li>default social asset path: <code>{socialImagePath}</code></li>
        <li>canonical url: <code>{pageCanonicalUrl}</code></li>
      </ul>
    </main>
  </body>
</html>
