---
import type { DomainEntry } from "../../data/domains/types";
import { homePage } from "../../data/home";
import { homePath } from "../../lib/paths";

interface Props {
  domain: DomainEntry;
}

const { domain } = Astro.props;
const previewItems = domain.belongsHere.slice(0, 3);

const emailLink = homePage.contactLinks.find((c) => c.key === "email");
const linkedInLink = homePage.contactLinks.find((c) => c.key === "linkedin");
---

<article
  class="domain-gate-shell"
  data-route-visibility="protected"
  data-gate-state="locked"
  data-protected-gate
  data-protected-proof-state="withheld"
>
  <p class="domain-gate-shell__back">
    <a class="domain-gate-shell__back-link" href={homePath}>Back home</a>
  </p>

  <header class="domain-gate-shell__header">
    <p class="domain-gate-shell__eyebrow">Protected case file</p>
    <h1 class="domain-gate-shell__title">{domain.title}</h1>
    <p class="domain-gate-shell__summary">
      This lane holds the real operating proof — detailed case studies, decisions, and evidence — but it's gated until you have the passcode.
    </p>
  </header>

  <section class="domain-gate-shell__panel" aria-labelledby="domain-gate-shell-status-heading">
    <div class="domain-gate-shell__terminal-bar" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="domain-gate-shell__status-row">
      <p class="domain-gate-shell__label" id="domain-gate-shell-status-heading">Status</p>
      <p class="domain-gate-shell__value">Locked boundary / proof withheld</p>
    </div>

    <p class="domain-gate-shell__thesis">{domain.thesis}</p>

    <div class="domain-gate-shell__grid">
      <section class="domain-gate-shell__card" aria-labelledby="domain-gate-shell-preview-heading">
        <p class="domain-gate-shell__label" id="domain-gate-shell-preview-heading">Inside this domain</p>
        <ul class="domain-gate-shell__list">
          {previewItems.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="domain-gate-shell__card" aria-labelledby="domain-gate-shell-scope-heading">
        <p class="domain-gate-shell__label" id="domain-gate-shell-scope-heading">Current cold-load policy</p>
        <ul class="domain-gate-shell__list">
          <li>Detailed case studies stay out of shipped HTML</li>
          <li>Evidence blocks stay out of shipped HTML</li>
          <li>This shell confirms the route is intentionally gated</li>
        </ul>
      </section>
    </div>

    <p class="domain-gate-shell__footer">
      Scope preview: <span>{domain.scope}</span>
    </p>
  </section>

  <!-- request access panel -->
  <section class="domain-gate-shell__panel domain-gate-shell__request-access" data-request-access-panel aria-labelledby="gate-request-heading">
    <div class="domain-gate-shell__terminal-bar" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <p class="domain-gate-shell__label" id="gate-request-heading">Request access</p>
    <p class="domain-gate-shell__request-copy">
      If you'd like to see the full case studies, reach out directly — I'll send the passcode.
    </p>
    <div class="domain-gate-shell__request-links">
      {emailLink && (
        <a class="domain-gate-shell__request-link" data-request-access-link="email" href={emailLink.href}>
          {emailLink.label} ({emailLink.href.replace("mailto:", "")})
        </a>
      )}
      {linkedInLink && (
        <a class="domain-gate-shell__request-link" data-request-access-link="linkedin" href={linkedInLink.href}>
          {linkedInLink.label}
        </a>
      )}
    </div>
  </section>

  <!-- passcode form -->
  <section class="domain-gate-shell__panel domain-gate-shell__unlock-panel" aria-labelledby="gate-passcode-heading">
    <div class="domain-gate-shell__terminal-bar" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <p class="domain-gate-shell__label" id="gate-passcode-heading">Passcode</p>

    <form class="domain-gate-shell__form" data-gate-form autocomplete="off">
      <div class="domain-gate-shell__form-row">
        <label for="gate-passcode" class="sr-only">Enter passcode</label>
        <input
          id="gate-passcode"
          class="domain-gate-shell__input"
          data-gate-passcode-input
          type="password"
          placeholder="Enter passcode"
          autocomplete="off"
          spellcheck="false"
        />
        <button
          class="domain-gate-shell__submit"
          data-gate-submit
          type="submit"
        >
          Unlock
        </button>
      </div>
      <p class="domain-gate-shell__status" data-gate-status="idle">
        <span class="domain-gate-shell__status-text" data-gate-status-text>Ready</span>
      </p>
    </form>
  </section>

  <!-- proof mount point (empty until unlock) -->
  <div class="domain-gate-shell__proof-mount" data-proof-mount></div>
</article>
