---
import type { ScreenshotItem } from "../../data/domains/types";

interface Props {
  screenshots: ScreenshotItem[];
}

const { screenshots } = Astro.props;
---

<figure class="screenshot-gallery" data-screenshot-gallery>
  <div class="screenshot-gallery__viewport" data-gallery-viewport>
    <ul class="screenshot-gallery__track" data-gallery-track>
      {screenshots.map((shot) => (
        <li class="screenshot-gallery__slide">
          <button
            class="screenshot-gallery__trigger"
            type="button"
            data-gallery-trigger
            data-full-src={shot.src}
            data-full-alt={shot.alt}
            data-caption={shot.caption || shot.alt}
          >
            <img
              class="screenshot-gallery__image"
              src={shot.src}
              alt={shot.alt}
              loading="lazy"
              decoding="async"
            />
          </button>
          {shot.caption && (
            <span class="screenshot-gallery__slide-caption">{shot.caption}</span>
          )}
        </li>
      ))}
    </ul>
  </div>

  <nav class="screenshot-gallery__nav" data-gallery-nav aria-label="Screenshot navigation">
    <button
      class="screenshot-gallery__arrow screenshot-gallery__arrow--prev"
      type="button"
      data-gallery-prev
      aria-label="Previous screenshots"
      disabled
    >
      &larr;
    </button>
    <div class="screenshot-gallery__dots" data-gallery-dots></div>
    <button
      class="screenshot-gallery__arrow screenshot-gallery__arrow--next"
      type="button"
      data-gallery-next
      aria-label="Next screenshots"
    >
      &rarr;
    </button>
  </nav>

  <dialog class="screenshot-gallery__lightbox" data-gallery-lightbox>
    <button
      class="screenshot-gallery__lightbox-close"
      type="button"
      data-gallery-lightbox-close
      aria-label="Close lightbox"
    >
      &times;
    </button>
    <img class="screenshot-gallery__lightbox-image" data-gallery-lightbox-img src="" alt="" />
    <p class="screenshot-gallery__lightbox-caption" data-gallery-lightbox-caption></p>
  </dialog>
</figure>

<script>
  import { initGalleries } from "./screenshot-gallery-init";
  initGalleries();
  document.addEventListener("astro:page-load", initGalleries);
</script>
