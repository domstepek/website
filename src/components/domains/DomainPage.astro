---
import { getDomainBySlug } from "../../data/domains";
import { buildDomainProofViewModel } from "../../data/domains/domain-view-model";
import type { DomainEntry } from "../../data/domains/types";
import { assetPath, domainPath, homePath } from "../../lib/paths";
import MermaidDiagram from "../diagrams/MermaidDiagram.astro";
import DomainGateShell from "./DomainGateShell.astro";
import ScreenshotGallery from "./ScreenshotGallery.astro";

interface Props {
  domain: DomainEntry;
  gateState?: "locked" | "open";
}

const { domain, gateState = "open" } = Astro.props;
const { title, thesis, scope, belongsHere, flagships = [], supportingWork, relatedDomains = [] } = domain;

const toVisualSrc = (source: string) =>
  source.startsWith("http://") || source.startsWith("https://")
    ? source
    : assetPath(source);

const relatedEntries = relatedDomains
  .map((slug) => getDomainBySlug(slug))
  .filter((entry): entry is DomainEntry => Boolean(entry));

const flagshipItems = flagships.map((flagship) => ({
  ...flagship,
  proofLinks: flagship.proofLinks ?? [],
  visual: flagship.visual
    ? {
        ...flagship.visual,
        src: flagship.visual.src ? toVisualSrc(flagship.visual.src) : undefined,
      }
    : undefined,
  screenshots: (flagship.screenshots ?? []).map((s) => ({
    ...s,
    src: toVisualSrc(s.src),
  })),
}));

const supportingItems = supportingWork.map((item) => ({
  ...item,
  proofLinks: item.proofLinks ?? [],
  relatedEntries: (item.relatedDomains ?? [])
    .map((slug) => getDomainBySlug(slug))
    .filter((entry): entry is DomainEntry => Boolean(entry)),
}));

/*
 * When gateState is "locked", build the proof view-model and serialise it
 * as a JSON blob inside a hidden <script> tag so the browser unlock path
 * can mount proof without a second network request. The JSON never renders
 * visible DOM, keeping proof withheld from cold-load inspection.
 */
const proofPayload = gateState === "locked"
  ? JSON.stringify(buildDomainProofViewModel(domain, assetPath, domainPath))
  : null;

const gateHashEnv = import.meta.env.PUBLIC_GATE_HASH ?? "";
---

{gateState === "locked" ? (
  <DomainGateShell domain={domain} />
  <script
    type="application/json"
    id="domain-proof-payload"
    data-proof-payload
    set:html={proofPayload}
  />
  <script
    type="application/json"
    id="domain-gate-config"
    data-gate-config
    set:html={JSON.stringify({
      hash: gateHashEnv,
      homePath: homePath,
      storageKey: "portfolio-gate:v1",
    })}
  />
  <script>
    import { initDomainGate } from "./domain-gate-client";
    initDomainGate();
  </script>
) : (
<article class="domain-page" data-domain-page data-route-visibility="protected" data-gate-state="open">
  <p class="domain-page__back">
    <a class="domain-page__back-link" data-back-home href={homePath}>Back home</a>
  </p>

  <header class="domain-page__intro">
    <h1 class="domain-page__title">{title}</h1>
    <p class="domain-page__thesis" data-domain-thesis>{thesis}</p>
  </header>

  <section class="domain-page__section" aria-labelledby="belongs-here-heading">
    <h2 class="domain-page__section-title" id="belongs-here-heading">The kind of work I do here</h2>
    <ul class="domain-page__list">
      {belongsHere.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <p class="domain-page__scope">
      <strong>Scope:</strong> {scope}
    </p>
  </section>

  {flagshipItems.length > 0 && (
    <section
      class="domain-page__section flagship-highlights"
      aria-labelledby="flagship-highlights-heading"
      data-flagship-highlights
    >
      <h2 class="domain-page__section-title" id="flagship-highlights-heading">Flagship highlights</h2>
      {flagshipItems.map((flagship) => (
        <article class="supporting-work__item flagship" id={`flagship-${flagship.slug}`} data-flagship>
          <header class="flagship__header">
            <h3 class="supporting-work__title flagship__title" data-flagship-title>{flagship.title}</h3>
            <p class="supporting-work__context flagship__summary">{flagship.summary}</p>
          </header>

          <div class="flagship__facts">
            <p class="domain-page__scope flagship__line" data-flagship-problem>
              <strong>Problem:</strong> {flagship.problem}
            </p>

            <p class="domain-page__scope flagship__line" data-flagship-role>
              <strong>Role:</strong> {flagship.role}
            </p>
          </div>

          <div class="flagship__grid">
            <section class="flagship__group" data-flagship-constraints>
              <p class="flagship__label">
                <strong>Constraints:</strong>
              </p>
              <ul class="domain-page__list flagship__list">
                {flagship.constraints.map((constraint) => (
                  <li>{constraint}</li>
                ))}
              </ul>
            </section>

            <section class="flagship__group" data-flagship-decisions>
              <p class="flagship__label">
                <strong>Decisions:</strong>
              </p>
              <ul class="domain-page__list flagship__list">
                {flagship.decisions.map((decision) => (
                  <li>{decision}</li>
                ))}
              </ul>
            </section>

            <section class="flagship__group" data-flagship-outcomes>
              <p class="flagship__label">
                <strong>Outcomes:</strong>
              </p>
              <ul class="domain-page__list flagship__list">
                {flagship.outcomes.map((outcome) => (
                  <li>{outcome}</li>
                ))}
              </ul>
            </section>

            <section class="flagship__group" data-flagship-stack>
              <p class="flagship__label">
                <strong>Stack:</strong>
              </p>
              <ul class="domain-page__list flagship__list">
                {flagship.stack.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </section>
          </div>

          {flagship.proofLinks.length > 0 && (
            <p class="supporting-work__links flagship__links" data-flagship-proof-links>
              <strong>Proof:</strong>{" "}
              {flagship.proofLinks.map((link, index) => (
                <>
                  <a data-flagship-proof-link href={link.href}>
                    {link.label}
                  </a>
                  {index < flagship.proofLinks.length - 1 ? ", " : ""}
                </>
              ))}
            </p>
          )}

          {flagship.visual && flagship.visual.mermaid && (
            <MermaidDiagram
              definition={flagship.visual.mermaid}
              alt={flagship.visual.alt}
              caption={flagship.visual.caption}
            />
          )}

          {flagship.visual && !flagship.visual.mermaid && flagship.visual.src && (
            <figure class="flagship__figure" data-flagship-visual>
              <img
                class="flagship__image"
                src={flagship.visual.src}
                alt={flagship.visual.alt}
                loading="lazy"
                decoding="async"
              />
              {flagship.visual.caption && (
                <figcaption class="flagship__caption">{flagship.visual.caption}</figcaption>
              )}
            </figure>
          )}

          {flagship.screenshots.length > 0 && (
            <ScreenshotGallery screenshots={flagship.screenshots} />
          )}
        </article>
      ))}
    </section>
  )}

  <section class="domain-page__section supporting-work" aria-labelledby="supporting-work-heading" data-supporting-work>
    <h2 class="domain-page__section-title" id="supporting-work-heading">Supporting work</h2>
    {supportingItems.map((item) => (
      <article class="supporting-work__item" data-supporting-item>
        <h3 class="supporting-work__title">{item.title}</h3>
        <p class="supporting-work__context">{item.context}</p>
        {item.proofLinks.length > 0 && (
          <p class="supporting-work__links">
            <strong>Proof:</strong>{" "}
            {item.proofLinks.map((link, index) => (
              <>
                <a data-proof-link href={link.href}>
                  {link.label}
                </a>
                {index < item.proofLinks.length - 1 ? ", " : ""}
              </>
            ))}
          </p>
        )}
        {(item.overlapNote || item.relatedEntries.length > 0) && (
          <p class="supporting-work__overlap">
            <strong>Overlap:</strong>{" "}
            {item.overlapNote ? `${item.overlapNote} ` : "Also touches "}
            {item.relatedEntries.map((entry, index) => (
              <>
                <a href={domainPath(entry.slug)}>{entry.title}</a>
                {index < item.relatedEntries.length - 1 ? ", " : ""}
              </>
            ))}
            {item.relatedEntries.length > 0 ? "." : ""}
          </p>
        )}
      </article>
    ))}
  </section>

  {relatedEntries.length > 0 && (
    <section class="domain-page__section" aria-labelledby="related-domains-heading">
      <h2 class="domain-page__section-title" id="related-domains-heading">Nearby domains</h2>
      <p class="domain-page__nearby">
        When a project crosses boundaries, it usually lands closest to{" "}
        {relatedEntries.map((entry, index) => (
          <>
            <a href={domainPath(entry.slug)}>{entry.title}</a>
            {index < relatedEntries.length - 1 ? ", " : ""}
          </>
        ))}
        .
      </p>
    </section>
  )}
</article>
)}
