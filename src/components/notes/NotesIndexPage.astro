---
import type { CollectionEntry } from "astro:content";
import { homePath, notePath } from "../../lib/paths";
import TerminalPanel from "../layout/TerminalPanel.astro";

interface Props {
  notes: CollectionEntry<"notes">[];
}

const { notes } = Astro.props;

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  })
    .format(value)
    .toLowerCase();
---

<div class="notes-index" data-notes-index>
  <p class="notes-index__back">
    <a class="notes-index__back-link" href={homePath}>Back home</a>
  </p>

  <TerminalPanel>
    <section class="notes-index__intro">
      <h1>Notes</h1>
      <p>
        Short field notes on system shape, product decisions, and the small implementation details
        that either clarify a workflow or quietly make it worse.
      </p>
    </section>

    <div class="notes-index__list">
      {
        notes.map((note) => (
          <article class="notes-index__item" data-note-item>
            <div class="notes-index__meta">
              <time data-note-date datetime={note.data.published.toISOString()}>
                {formatDate(note.data.published)}
              </time>
            </div>
            <h2 class="notes-index__title" data-note-title>
              <a data-note-link href={notePath(note.slug)}>
                {note.data.title}
              </a>
            </h2>
            <p data-note-summary>{note.data.summary}</p>
          </article>
        ))
      }
    </div>
  </TerminalPanel>
</div>
