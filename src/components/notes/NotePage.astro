---
import type { CollectionEntry } from "astro:content";
import { notesPath } from "../../lib/paths";
import TerminalPanel from "../layout/TerminalPanel.astro";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;

const formatDate = (value: Date) =>
  new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
    timeZone: "UTC",
  })
    .format(value)
    .toLowerCase();
---

<div class="note-page" data-note-page>
  <p class="note-page__back">
    <a class="note-page__back-link" href={notesPath}>Back to notes</a>
  </p>

  <TerminalPanel>
    <section class="note-page__intro">
      <h1 data-note-title>{note.data.title}</h1>
      <p class="note-page__meta">
        <time data-note-date datetime={note.data.published.toISOString()}>
          {formatDate(note.data.published)}
        </time>
      </p>
      <p class="note-page__summary">{note.data.summary}</p>
    </section>

    <article class="note-page__body" data-note-body>
      <slot />
    </article>
  </TerminalPanel>
</div>
