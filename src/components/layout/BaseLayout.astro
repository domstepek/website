---
import "../../styles/global.css";
import { siteConfig } from "../../data/site";
import { assetPath, canonicalUrl, homePath } from "../../lib/paths";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title: rawTitle,
  description: rawDescription,
  canonicalPath = "/",
  ogImage = siteConfig.defaultSocialImage,
  noindex = false,
} = Astro.props;

const title = rawTitle?.trim() ? rawTitle.trim() : siteConfig.defaultTitle;
const description = rawDescription?.trim()
  ? rawDescription.trim()
  : siteConfig.defaultDescription;
const pageTitle = title === siteConfig.defaultTitle ? title : `${title} | ${siteConfig.name}`;
const pageCanonicalUrl = canonicalUrl(canonicalPath);
const ogImageSource = /^https?:\/\//.test(ogImage) ? ogImage : assetPath(ogImage);
const pageOgImage = new URL(ogImageSource, siteConfig.siteUrl).toString();
const faviconHref = assetPath(siteConfig.defaultFavicon);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageCanonicalUrl} />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageCanonicalUrl} />
    <meta property="og:image" content={pageOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="shell site-header__inner">
          <a class="site-title" href={homePath}>{siteConfig.name}</a>
        </div>
      </header>
      <main class="shell site-main" id="main-content">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="shell site-footer__inner">
          <p>minimal shell for systems, products, and tooling.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
