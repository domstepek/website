---
import { homePage } from "../../data/home";
import { domains } from "../../data/domains";
import { domainPath } from "../../lib/paths";

const homeDomains = domains.map((domain) => ({
  ...domain,
  href: domainPath(domain.slug),
}));

const isExternalHttpLink = (href: string) => href.startsWith("https://");
---

<div class="home-page" data-home-page>
  <section class="home-page__hero" data-home-hero>
    <p class="home-page__eyebrow">{homePage.eyebrow}</p>
    <h1>{homePage.title}</h1>
    <p class="home-page__lead">{homePage.lead}</p>
    <p>{homePage.domainIntro}</p>
  </section>

  <nav class="home-page__section" aria-labelledby="home-domain-nav-title" data-home-domain-nav>
    <h2 id="home-domain-nav-title">start with a domain</h2>
    <ul class="home-page__domain-list">
      {
        homeDomains.map((domain) => (
          <li class="home-page__domain-item">
            <a class="home-page__domain-link" data-home-domain-link href={domain.href}>
              {domain.title}
            </a>
            <p class="home-page__domain-summary">{domain.summary}</p>
          </li>
        ))
      }
    </ul>
  </nav>

  <section class="home-page__section" aria-labelledby="home-contact-title">
    <h2 id="home-contact-title">{homePage.contactHeading}</h2>
    <ul class="home-page__contact-list" data-home-contact-links>
      {
        homePage.contactLinks.map((link) => (
          <li>
            <a
              data-home-contact-link
              href={link.href}
              rel={isExternalHttpLink(link.href) ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="home-page__section" aria-labelledby="home-freshness-title">
    <h2 id="home-freshness-title">{homePage.freshness.label}</h2>
    <p class="home-page__freshness-copy" data-home-freshness>
      {homePage.freshness.value}
      <span class="home-page__freshness-note"> {homePage.freshness.note}</span>
    </p>
  </section>
</div>

<style>
  .home-page {
    display: grid;
    gap: clamp(1.75rem, 4vw, 3rem);
  }

  .home-page__hero,
  .home-page__section {
    display: grid;
    gap: 1rem;
  }

  .home-page__eyebrow {
    margin: 0;
    color: var(--text);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }

  .home-page__lead,
  .home-page__freshness-copy {
    max-width: 34rem;
    color: var(--text);
    font-size: clamp(1.08rem, 1.02rem + 0.35vw, 1.3rem);
    line-height: 1.65;
  }

  .home-page__domain-list,
  .home-page__contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .home-page__domain-list {
    display: grid;
    gap: 1rem;
    max-width: var(--measure);
  }

  .home-page__domain-item {
    display: grid;
    gap: 0.35rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .home-page__domain-item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .home-page__domain-link {
    display: inline-block;
    font-size: clamp(1.08rem, 1.02rem + 0.35vw, 1.22rem);
  }

  .home-page__domain-summary {
    max-width: 34rem;
  }

  .home-page__contact-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
  }

  .home-page__contact-list a {
    display: inline-block;
  }

  .home-page__contact-list a:focus-visible,
  .home-page__domain-link:focus-visible {
    outline-offset: 0.22rem;
  }

  .home-page__freshness-note {
    color: var(--muted);
  }

  @media (max-width: 40rem) {
    .home-page {
      gap: 1.75rem;
    }
  }
</style>
